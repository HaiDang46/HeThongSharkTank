                        <div class="hotdeal__item">
                            <img src="~/Content/icons/trả gop.gif"
                                 alt="Trả góp 0%"
                                 class="hotdeal__item-gif">
                            <p class="hotdeal__title">TRẢ GÓP 0%</p>
                        </div>
                    </a>

                    <a href="#" aria-label="Apple Education"
                       class="hotdeal__link">
                        <div class="hotdeal__item">
                            <img src="~/Content/icons/apple.gif"
                                 alt="Apple Education"
                                 class="hotdeal__item-gif">
                            <p class="hotdeal__title">
                                APPLE
                                EDUCATION
                            </p>
                        </div>
                    </a>

                    <a href="#" aria-label="Free ship"
                       class="hotdeal__link">
                        <div class="hotdeal__item">
                            <img src="~/Content/icons/free.gif"
                                 alt="Free ship"
                                 class="hotdeal__item-gif">
                            <p class="hotdeal__title">FREE SHIP</p>
                        </div>
                    </a>

                    <a href="#" aria-label="Đổi điểm THPT 2025"
                       class="hotdeal__link">
                        <div class="hotdeal__item">
                            <img src="~/Content/icons/doidiem.gif"
                                 alt="Đổi điểm THPT 2025"
