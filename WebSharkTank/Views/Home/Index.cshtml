                                </a>
                            </div>
                            <div class="slide-2">
                                <a href>
                                    <img src="~/Content/img/slide2/2.png"
                                         alt>
                                </a>
                            </div>
                            <div class="slide-3">
                                <a href>
                                    <img src="https://file.hstatic.net/200000722513/file/gearvn-back-to-school-25-slider.png"
                                         alt>
                                </a>
                            </div>
                            <div class="slide-4">
                                <a href>
                                    <img src="https://file.hstatic.net/200000722513/file/gearvn-asus-sat-canh-nhe-ganh-hoc-choi-slider.jpg"
                                         alt>
                                </a>
                            </div>
                            <div class="slide-5">
                                <a href>
                                    <img src="https://file.hstatic.net/200000722513/file/gearvn-acer-back-to-school-2025-slider.jpg"
