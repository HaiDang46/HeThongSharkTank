                            <div id="slide1" class="tabzy-panel">
                                <div id="my-slider1"
                                     class="slidezy-container"></div>
                            </div>
                            <div id="slide2" class="tabzy-panel" hidden>
                                <div id="my-slider2"
                                     class="slidezy-container"></div>
                            </div>
                            <div id="slide3" class="tabzy-panel" hidden>
                                <div id="my-slider3"
                                     class="slidezy-container"></div>
                            </div>
                            <div id="slide4" class="tabzy-panel" hidden>
                                <div id="my-slider4"
                                     class="slidezy-container"></div>
                            </div>
                            <div id="slide5" class="tabzy-panel" hidden>
                                <div id="my-slider5"
                                     class="slidezy-container"></div>
                            </div>
                            <div id="slide6" class="tabzy-panel" hidden>
                                <div id="my-slider6"
                                     class="slidezy-container"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
