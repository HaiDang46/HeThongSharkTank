    <div class="home__container">
        <div class="hotdeal">
            <div class="hotdeal__wrap">
                <h2 class="hotdeal__titlemain">ƯU ĐÃI HÓT</h2>
                <div class="hotdeal__list">
                    <a href="#" aria-label="Giờ vàng giá sốc"
                       class="hotdeal__link">
                        <div class="hotdeal__item">
                            <img src="~/Content/icons/unnamed.gif"
                                 alt="Giờ vàng giá sốc"
                                 class="hotdeal__item-gif">
                            <p class="hotdeal__title">
                                GIỜ VÀNG GIÁ
                                SỐC
                            </p>
                        </div>
                    </a>

                    <a href="#" aria-label="Tải app"
                       class="hotdeal__link">
                        <div class="hotdeal__item">
                            <img src="~/Content/icons/250k.gif"
                                 alt="Tải app" class="hotdeal__item-gif">
                            <p class="hotdeal__title">TẢI APP</p>
                        </div>
                    </a>

                    <a href="#" aria-label="Laptop AI"
                       class="hotdeal__link">
                        <div class="hotdeal__item">
                            <img src="~/Content/icons/Ai.gif"
                                 alt="Laptop AI"
                                 class="hotdeal__item-gif">
