                            <p class="hotdeal__title">
                                ĐỔI ĐIỂM THPT
                                2025
                            </p>
                        </div>
                    </a>
                </div>
            </div>
        </div>

        <div class="flashsales">
            <div class="flashsales__row">
                <div class="flashsales-wrap">
                    <div class="flashsale-countdown">
                        <span class="flashsale-title">
                            FLASH
                            <span>SALE</span>
                        </span>
                        <span class="flashsale-text">
                            Kết thúc
                            trong
                        </span>
                        <div id="countdown">
                            <span id="hours">00</span> :
                            <span id="minutes">00</span> :
                            <span id="seconds">00</span>
                        </div>
                    </div>
                    <div class="sample-3">
                        <div class="tabzy-wrapper">
                            <ul id="sliding-tabs"
                                class="tabzy-tabs sliding">
                                <li>
                                    <a href="#slide1">
                                        Laptop
                                        <br><span>
                                            Giảm đến
                                            40%
                                        </span>
                                    </a>
                                </li>
                                <li>
                                    <a href="#slide2">
                                        Linh
                                        Kiện<br><span>
                                            Giảm đến
                                            40%
                                        </span>
                                    </a>
                                </li>
                                <li>
                                    <a href="#slide3">
                                        Màn
