                            <a href>
                                <img src="https://file.hstatic.net/200000722513/file/gearvn-build-pc-slider-right-t8.png"
                                     alt>
                            </a>
                        </div>
                        <div class="promo-grid__item">
                            <a href>
                                <img src="https://file.hstatic.net/200000722513/file/gearvn-ban-phim-slider-right-t8.png"
