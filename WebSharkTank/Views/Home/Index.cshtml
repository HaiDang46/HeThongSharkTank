                                            Giảm đến
                                            40%
                                        </span>
                                    </a>
                                </li>
                                <li>
                                    <a href="#slide5">
                                        Camera - Thiết bị
                                        Mạng<br><span>
                                            Giảm đến
                                            40%
                                        </span>
                                    </a>
                                </li>
                                <li>
                                    <a href="#slide6">
                                        Loa - Phụ
                                        Kiện<br><span>
                                            Giảm đến
                                            40%
                                        </span>
                                    </a>
                                </li>
                            </ul>
