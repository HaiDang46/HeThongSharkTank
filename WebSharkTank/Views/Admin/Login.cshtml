@{
    ViewBag.Title = "Đăng nhập quản trị";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <title>Đăng nhập quản trị | Website quản trị v2.0</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" type="text/css" href="@Url.Content("~/Giao diện admin/vendor/bootstrap/css/bootstrap.min.css")">
    <link rel="stylesheet" type="text/css" href="@Url.Content("~/Giao diện admin/fonts/font-awesome-4.7.0/css/font-awesome.min.css")">
    <link rel="stylesheet" type="text/css" href="@Url.Content("~/Giao diện admin/vendor/animate/animate.css")">
    <link rel="stylesheet" type="text/css" href="@Url.Content("~/Giao diện admin/vendor/css-hamburgers/hamburgers.min.css")">
    <link rel="stylesheet" type="text/css" href="@Url.Content("~/Giao diện admin/vendor/select2/select2.min.css")">
    <link rel="stylesheet" type="text/css" href="@Url.Content("~/Giao diện admin/css/util.css")">
    <link rel="stylesheet" type="text/css" href="@Url.Content("~/Giao diện admin/css/main.css")">
    <link href="https://stackpath.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-sweetalert/1.0.1/sweetalert.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/sweetalert/2.1.2/sweetalert.min.js"></script>
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.8.2/css/all.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/jquery-confirm/3.3.2/jquery-confirm.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/boxicons@latest/css/boxicons.min.css">
    <link rel="stylesheet" href="https://unpkg.com/boxicons@latest/css/boxicons.min.css">
</head>
<body>
    <div class="limiter">
        <div class="container-login100">
            <div class="wrap-login100">
                <div class="login100-pic js-tilt" data-tilt>
                    <img src="@Url.Content("~/Giao diện admin/images/team.jpg")" alt="IMG">
                </div>
                <form class="login100-form validate-form" id="loginForm">
                    <span class="login100-form-title">
                        <b>ĐĂNG NHẬP HỆ THỐNG POS</b>
                    </span>
                    @Html.AntiForgeryToken()
                    <div class="wrap-input100 validate-input">
                        <input class="input100" type="text" placeholder="Email đăng nhập" name="email" id="email">
                        <span class="focus-input100"></span>
                        <span class="symbol-input100">
                            <i class='bx bx-user'></i>
                        </span>
                    </div>
                    <div class="wrap-input100 validate-input">
                        <input autocomplete="off" class="input100" type="password" placeholder="Mật khẩu" name="password" id="password-field">
                        <span toggle="#password-field" class="bx fa-fw bx-hide field-icon click-eye"></span>
                        <span class="focus-input100"></span>
                        <span class="symbol-input100">
                            <i class='bx bx-key'></i>
                        </span>
                    </div>
                    <div class="container-login100-form-btn">
                        <input type="button" value="Đăng nhập" id="submit" onclick="validate()" />
                    </div>
                    <div class="text-right p-t-12">
                        <a class="txt2" href="@Url.Action("ForgotPassword", "Admin")">
                            Bạn quên mật khẩu?
                        </a>
                    </div>
                    <div class="text-center p-t-70 txt2">
                        Phần mềm quản lý bán hàng <i class="far fa-copyright" aria-hidden="true"></i>
                        <script type="text/javascript">document.write(new Date().getFullYear());</script> 
                        <a class="txt2" href="#"> dev Gia Bảo </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <script src="https://unpkg.com/boxicons@latest/dist/boxicons.js"></script>
    <script src="@Url.Content("~/Giao diện admin/vendor/jquery/jquery-3.2.1.min.js")"></script>
    <script src="@Url.Content("~/Giao diện admin/vendor/bootstrap/js/popper.js")"></script>
    <script src="@Url.Content("~/Giao diện admin/vendor/bootstrap/js/bootstrap.min.js")"></script>
    <script src="@Url.Content("~/Giao diện admin/vendor/select2/select2.min.js")"></script>
    <script type="text/javascript">
        //show - hide mật khẩu
        $(".click-eye").click(function () {
            $(this).toggleClass("bx-show bx-hide");
            var input = $($(this).attr("toggle"));
            if (input.attr("type") == "password") {
                input.attr("type", "text");
            } else {
                input.attr("type", "password");
            }
        });

        // Hàm validate và đăng nhập
        function validate() {
            var email = document.getElementById("email").value.trim();
            var password = document.getElementById("password-field").value;

            if (email == "" && password == "") {
                swal({
                    title: "",
                    text: "Bạn chưa điền đầy đủ thông tin đăng nhập...",
                    icon: "error",
                    close: true,
                    button: "Thử lại",
                });
                return false;
            }

            if (email == null || email == "") {
                swal({
                    title: "",
                    text: "Email đang để trống...",
                    icon: "warning",
                    close: true,
                    button: "Thử lại",
                });
                return false;
            }

            if (password == null || password == "") {
                swal({
                    title: "",
                    text: "Mật khẩu đang để trống...",
                    icon: "warning",
                    close: true,
                    button: "Thử lại",
                });
                return false;
            }

            // Gọi API đăng nhập
            var formData = new FormData();
            formData.append('email', email);
            formData.append('password', password);
            formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]')?.value || '');

            var submitBtn = document.getElementById("submit");
            submitBtn.disabled = true;
            submitBtn.value = "Đang đăng nhập...";

            fetch('@Url.Action("Login", "Admin")', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    swal({
                        title: "",
                        text: data.message || "Xin chào " + (data.userName || "Admin"),
                        icon: "success",
                        close: true,
                        button: false,
                    });
                    setTimeout(function() {
                        window.location = data.redirectUrl || '@Url.Action("Dashboard", "Admin")';
                    }, 1000);
                } else {
                    swal({
                        title: "",
                        text: data.message || "Sai thông tin đăng nhập hãy kiểm tra lại...",
                        icon: "error",
                        close: true,
                        button: "Thử lại",
                    });
                    submitBtn.disabled = false;
                    submitBtn.value = "Đăng nhập";
                }
            })
            .catch(error => {
                console.error('Error:', error);
                swal({
                    title: "",
                    text: "Có lỗi xảy ra khi đăng nhập. Vui lòng thử lại.",
                    icon: "error",
                    close: true,
                    button: "Thử lại",
                });
                submitBtn.disabled = false;
                submitBtn.value = "Đăng nhập";
            });
        }

        // Cho phép nhấn Enter để đăng nhập
        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById("email").addEventListener("keypress", function(event) {
                if (event.key === "Enter") {
                    event.preventDefault();
                    validate();
                }
            });
            document.getElementById("password-field").addEventListener("keypress", function(event) {
                if (event.key === "Enter") {
                    event.preventDefault();
                    validate();
                }
            });
        });
    </script>
</body>
</html>

