@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewBag.Title - Quản trị Admin</title>
    
    <!-- Main CSS-->
    <link rel="stylesheet" type="text/css" href="@Url.Content("~/Giao diện admin/doc/css/main.css")">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/boxicons@latest/css/boxicons.min.css">
    <link rel="stylesheet" href="https://unpkg.com/boxicons@latest/css/boxicons.min.css">
    
    <!-- Font-icon css-->
    <link rel="stylesheet" type="text/css" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/sweetalert/2.1.2/sweetalert.min.js"></script>
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.8.2/css/all.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/jquery-confirm/3.3.2/jquery-confirm.min.css">
    @RenderSection("Styles", required: false)
</head>
<body onload="time()" class="app sidebar-mini rtl">
    <!-- Navbar-->
    <header class="app-header">
        <!-- Sidebar toggle button-->
        <a class="app-sidebar__toggle" href="#" data-toggle="sidebar" aria-label="Hide Sidebar"></a>
        <!-- Navbar Right Menu-->
        <ul class="app-nav">
            <!-- User Menu-->
            <li>
                <a class="app-nav__item" href="@Url.Action("Logout", "Admin")" onclick="event.preventDefault(); document.getElementById('logoutForm').submit();">
                    <i class='bx bx-log-out bx-rotate-180'></i>
                </a>
                @using (Html.BeginForm("Logout", "Admin", FormMethod.Post, new { id = "logoutForm", style = "display:none;" }))
                {
                    @Html.AntiForgeryToken()
                }
            </li>
        </ul>
    </header>
    
    <!-- Sidebar menu-->
    <div class="app-sidebar__overlay" data-toggle="sidebar"></div>
    <aside class="app-sidebar">
        <div class="app-sidebar__user">
            <img class="app-sidebar__user-avatar" src="@Url.Content("~/Giao diện admin/images/hay.jpg")" width="50px" alt="User Image">
            <div>
                <p class="app-sidebar__user-name"><b>@(Session["UserName"] ?? "Admin")</b></p>
                <p class="app-sidebar__user-designation">Chào mừng bạn trở lại</p>
            </div>
        </div>
        <hr>
        <ul class="app-menu">
            <li><a class="app-menu__item" href="@Url.Action("Index", "Home")" target="_blank"><i class='app-menu__icon bx bx-home'></i><span class="app-menu__label">Về trang chủ</span></a></li>
            <li><a class="app-menu__item" href="@Url.Action("Dashboard", "Admin")"><i class='app-menu__icon bx bx-tachometer'></i><span class="app-menu__label">Bảng điều khiển</span></a></li>
            <li><a class="app-menu__item" href="@Url.Action("Index", "Admin")"><i class='app-menu__icon bx bx-purchase-tag-alt'></i><span class="app-menu__label">Quản lý sản phẩm</span></a></li>
            <li><a class="app-menu__item @(ViewBag.ActiveMenu == "Orders" ? "active" : "")" href="@Url.Action("Orders", "Admin")"><i class='app-menu__icon bx bx-task'></i><span class="app-menu__label">Quản lý đơn hàng</span></a></li>
            <li><a class="app-menu__item @(ViewBag.ActiveMenu == "Customers" ? "active" : "")" href="@Url.Action("Customers", "Admin")"><i class='app-menu__icon bx bx-user-voice'></i><span class="app-menu__label">Quản lý khách hàng</span></a></li>
            <li><a class="app-menu__item @(ViewBag.ActiveMenu == "Users" ? "active" : "")" href="@Url.Action("Users", "Admin")"><i class='app-menu__icon bx bx-id-card'></i><span class="app-menu__label">Quản lý nhân viên</span></a></li>
            <li><a class="app-menu__item" href="#"><i class='app-menu__icon bx bx-dollar'></i><span class="app-menu__label">Bảng kê lương</span></a></li>
            <li><a class="app-menu__item" href="#"><i class='app-menu__icon bx bx-pie-chart-alt-2'></i><span class="app-menu__label">Báo cáo doanh thu</span></a></li>
            <li><a class="app-menu__item" href="#"><i class='app-menu__icon bx bx-calendar-check'></i><span class="app-menu__label">Lịch công tác</span></a></li>
            <li><a class="app-menu__item" href="#"><i class='app-menu__icon bx bx-cog'></i><span class="app-menu__label">Cài đặt hệ thống</span></a></li>
        </ul>
    </aside>
    
    <main class="app-content">
        @RenderBody()
        
        <div class="text-center" style="font-size: 13px; margin-top: 20px;">
            <p><b>Copyright
                <script type="text/javascript">document.write(new Date().getFullYear());</script> 
                Phần mềm quản lý bán hàng | dev Gia Bảo
            </b></p>
        </div>
    </main>
    
    <script src="@Url.Content("~/Giao diện admin/doc/js/jquery-3.2.1.min.js")"></script>
    <script src="@Url.Content("~/Giao diện admin/doc/js/popper.min.js")"></script>
    <script src="https://unpkg.com/boxicons@latest/dist/boxicons.js"></script>
    <script src="@Url.Content("~/Giao diện admin/doc/js/bootstrap.min.js")"></script>
    <script src="@Url.Content("~/Giao diện admin/doc/js/main.js")"></script>
    <script src="@Url.Content("~/Giao diện admin/doc/js/plugins/pace.min.js")"></script>
    <script type="text/javascript" src="@Url.Content("~/Giao diện admin/doc/js/plugins/chart.js")"></script>
    
    <script type="text/javascript">
        //Thời Gian
        function time() {
            var today = new Date();
            var weekday = new Array(7);
            weekday[0] = "Chủ Nhật";
            weekday[1] = "Thứ Hai";
            weekday[2] = "Thứ Ba";
            weekday[3] = "Thứ Tư";
            weekday[4] = "Thứ Năm";
            weekday[5] = "Thứ Sáu";
            weekday[6] = "Thứ Bảy";
            var day = weekday[today.getDay()];
            var dd = today.getDate();
            var mm = today.getMonth() + 1;
            var yyyy = today.getFullYear();
            var h = today.getHours();
            var m = today.getMinutes();
            var s = today.getSeconds();
            m = checkTime(m);
            s = checkTime(s);
            nowTime = h + " giờ " + m + " phút " + s + " giây";
            if (dd < 10) {
                dd = '0' + dd
            }
            if (mm < 10) {
                mm = '0' + mm
            }
            today = day + ', ' + dd + '/' + mm + '/' + yyyy;
            var clockElement = document.getElementById("clock");
            if (clockElement) {
                tmp = '<span class="date"> ' + today + ' - ' + nowTime + '</span>';
                clockElement.innerHTML = tmp;
            }
            clocktime = setTimeout("time()", "1000", "Javascript");

            function checkTime(i) {
                if (i < 10) {
                    i = "0" + i;
                }
                return i;
            }
        }
    </script>
    
    @RenderSection("Scripts", required: false)
</body>
</html>

