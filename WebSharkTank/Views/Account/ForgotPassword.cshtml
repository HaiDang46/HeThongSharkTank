@{
    ViewBag.Title = "Quên mật khẩu | Shark Tank";
    Layout = null;
    Response.ContentType = "text/html; charset=utf-8";
    Response.Charset = "utf-8";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quên mật khẩu | Shark Tank</title>
    <!-- Favicon -->
    <link rel="apple-touch-icon" sizes="76x76" href="@Url.Content("~/Content/favicon/apple-touch-icon.png")" />
    <link rel="icon" type="image/png" sizes="32x32" href="@Url.Content("~/Content/favicon/favicon-32x32.png")" />
    <link rel="icon" type="image/png" sizes="16x16" href="@Url.Content("~/Content/favicon/favicon-16x16.png")" />
    <link rel="manifest" href="@Url.Content("~/Content/favicon/site.webmanifest")" />
    <meta name="msapplication-TileColor" content="#da532c" />
    <meta name="theme-color" content="#ffffff" />
    <!-- Fonts -->
    <link rel="stylesheet" href="@Url.Content("~/Content/fonts/stylesheet.css")" />
    <!-- Styles -->
    <link rel="stylesheet" href="@Url.Content("~/Content/css/main.css")" />
    <!-- Scripts -->
    <script src="@Url.Content("~/Content/js/scripts.js")"></script>
</head>
<body>
    <main class="auth">
        <!-- Auth intro -->
        <div class="auth__intro d-md-none">
            <img src="@Url.Content("~/Content/img/auth/forgot-password.png")" alt="" class="auth__intro-img" />
        </div>

        <!-- Auth content -->
        <div class="auth__content">
            <div class="auth__content-inner">
                <a href="@Url.Action("Index", "Home")" class="logo">
                    <img src="@Url.Content("~/Content/icons/logo.svg")" alt="Shark Tank" class="logo__img" />
                    <h2 class="logo__title">Shark Tank</h2>
                </a>
                <h1 class="auth__heading">Đặt lại mật khẩu</h1>
                <p class="auth__desc">Nhập email của bạn và chúng tôi sẽ gửi link để đặt lại mật khẩu.</p>

                <div id="forgot-password-message" class="auth__message message message--success" style="display: none;">
                    Chúng tôi đã gửi link đặt lại mật khẩu đến email của bạn!
                </div>

                <form id="forgot-password-form" action="javascript:void(0)" class="form auth__form auth__form-forgot" data-has-handler="true">
                    @Html.AntiForgeryToken()
                    <div class="form__group">
                        <div class="form__text-input">
                            <input type="email" name="email" id="forgot-email" placeholder="Email" class="form__input" required />
                            <img src="@Url.Content("~/Content/icons/message.svg")" alt="" class="form__input-icon" />
                            <img src="@Url.Content("~/Content/icons/form-error.svg")" alt="" class="form__input-icon-error" />
                        </div>
                        <p class="form__error">Email không đúng định dạng</p>
                    </div>
                    <div class="form__group auth__btn-group">
                        <button class="btn btn--primary auth__btn form__submit-btn">Đặt lại mật khẩu</button>
                    </div>
                </form>

                <p class="auth__text">
                    <a href="@Url.Action("Login", "Account")" class="auth__link auth__text-link">Quay lại Đăng nhập</a>
                </p>
            </div>
        </div>
    </main>

    <script>
        window.dispatchEvent(new Event("template-loaded"));
    </script>
    <script>
        // Handle form submission
        document.getElementById('forgot-password-form')?.addEventListener('submit', async function(e) {
            e.preventDefault();
            const email = document.getElementById('forgot-email')?.value;
            const messageEl = document.getElementById('forgot-password-message');

            if (!email) {
                alert('Vui lòng nhập email');
                return;
            }

            try {
                const formData = new FormData();
                formData.append('email', email);
                formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]')?.value || '');

                const response = await fetch('@Url.Action("ForgotPassword", "Account")', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();
                if (result.success) {
                    if (messageEl) {
                        messageEl.style.display = 'block';
                        messageEl.textContent = result.message || 'Chúng tôi đã gửi link đặt lại mật khẩu đến email của bạn!';
                    }
                    // Hide form after success
                    document.getElementById('forgot-password-form').style.display = 'none';
                } else {
                    alert(result.message || 'Có lỗi xảy ra!');
                }
            } catch (error) {
                console.error('Forgot password error:', error);
                alert('Có lỗi xảy ra khi gửi yêu cầu!');
            }
        });
    </script>
</body>
</html>

