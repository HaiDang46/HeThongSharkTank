@{
    ViewBag.Title = "Danh mục sản phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@{
    Response.ContentType = "text/html; charset=utf-8";
    Response.Charset = "utf-8";
}

<main class="product-page">
    <div class="container">
        <!-- Breadcrumbs -->
        <div class="product-container">
            <ul class="breadcrumbs">
                <li>
                    <a href="@Url.Action("Index", "Home")" class="breadcrumbs__link">
                        Trang chủ <img src="@Url.Content("~/Content/icons/arrow-right.svg")" alt />
                    </a>
                </li>
                <li><a class="breadcrumbs__link breadcrumbs__link--current">Danh mục</a></li>
            </ul>
        </div>
        <div class="product-container" style="display:grid;grid-template-columns:280px 1fr;gap:16px;">
            <!-- SIDEBAR FILTERS -->
            <aside class="category-sidebar">
                <div class="sidebar-head">
                    <h3 style="font-weight:800;margin:0">Bộ lọc</h3>
                    <button id="btn-close-filters" class="btn-icon" aria-label="Đóng bộ lọc">✕</button>
                </div>
                <div class="prod-info__card specs-card">
                    <div class="spec-card">
                        <h3 class="spec-card__title">🔎 Tìm kiếm</h3>
                        <input id="flt-q" class="search-bar__input" placeholder="Từ khóa (title/tags)" />
                    </div>
                </div>
                <div class="prod-info__card specs-card">
                    <div class="spec-card">
                        <h3 class="spec-card__title">📦 Loại</h3>
                        <ul id="flt-types" class="spec-list"></ul>
                    </div>
                </div>
                <div class="prod-info__card specs-card">
                    <div class="spec-card">
                        <h3 class="spec-card__title">🏷️ Thương hiệu</h3>
                        <ul id="flt-brands" class="spec-list"></ul>
                    </div>
                </div>
                <div class="prod-info__card specs-card">
                    <div class="spec-card">
                        <h3 class="spec-card__title">💰 Khoảng giá</h3>
                        <div class="spec-list">
                            <div>
                                <input id="flt-min" class="search-bar__input" placeholder="Từ (đ)">
                                <input id="flt-max" class="search-bar__input" placeholder="Đến (đ)">
                            </div>
                            <div class="price-caption">
                                <span>0đ</span>
                                <span>200.000.000đ</span>
                            </div>
                            <!-- Slider 2 đầu -->
                            <div class="price-slider" data-min="0" data-max="200000000" data-step="100000">
                                <div class="ps-track">
                                    <div class="ps-fill"></div>
                                </div>
                                <input type="range" class="ps-thumb ps-thumb--min" min="0" max="200000000" step="100000" value="0" aria-label="Giá tối thiểu">
                                <input type="range" class="ps-thumb ps-thumb--max" min="0" max="200000000" step="100000" value="200000000" aria-label="Giá tối đa">
                                <span class="ps-tip ps-tip--min">0</span>
                                <span class="ps-tip ps-tip--max">200,000,000</span>
                            </div>
                        </div>
                    </div>
                </div>
                <button id="flt-clear" class="btn btn--primary-red" style="width:100%">Xóa lọc</button>
            </aside>
            <!-- CONTENT -->
            <section>
                <!-- Mobile actions -->
                <div class="cat-mobilebar">
                    <button id="btn-open-filters" class="btn btn--outline">Bộ lọc</button>
                    <span id="resultCountMobile" class="cat-mobilebar__count">0 sản phẩm</span>
                </div>
                <!-- Top bar -->
                <div class="d-flex justify-content-between align-items-center" style="gap:12px;margin-bottom:12px;">
                    <div id="resultCount">Tìm thấy 0 sản phẩm</div>
                    <div class="d-flex align-items-center" style="gap:8px;">
                        <label for="sortSel" style="white-space:nowrap">Sắp xếp:</label>
                        <select id="sortSel" class="search-bar__input" style="min-width:220px">
                            <option value>Mặc định</option>
                            <option value="price-asc">Giá ↑</option>
                            <option value="price-desc">Giá ↓</option>
                            <option value="sold-desc">Bán chạy</option>
                            <option value="score-desc">Đánh giá</option>
                            <option value="title-asc">Tên A→Z</option>
                        </select>
                    </div>
                </div>
                <!-- GRID -->
                <div id="categoryGrid" class="row row-cols-4 row-cols-xl-4 row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-2"></div>
                <!-- Pagination -->
                <div id="pager" class="d-flex justify-content-center" style="gap:8px;margin:16px 0;"></div>
            </section>
        </div>
    </div>
</main>

<div id="filterBackdrop" class="filter-backdrop"></div>

@section Scripts {
    <script src="@Url.Content("~/Content/js/cart.js?v=2")"></script>
    <script src="@Url.Content("~/Content/js/category.js")"></script>
}

