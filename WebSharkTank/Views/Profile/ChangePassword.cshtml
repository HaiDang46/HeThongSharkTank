@{
    ViewBag.Title = "Đổi mật khẩu | Shark Tank";
    Layout = "~/Views/Shared/_Layout.cshtml";
    Response.ContentType = "text/html; charset=utf-8";
    Response.Charset = "utf-8";
}

<!-- MAIN -->
<main class="profile">
    <div class="container">
        <!-- Search bar -->
        <div class="profile-container">
            <form class="search-bar d-none d-md-flex" role="search" aria-label="Tìm kiếm" onsubmit="return false;">
                <input type="search" id="profile-search" placeholder="Tìm sản phẩm…"
                    class="search-bar__input" autocomplete="off" aria-label="Tìm sản phẩm" />
                <button class="search-bar__submit" type="button" aria-label="Tìm kiếm">
                    <img src="@Url.Content("~/Content/icons/search.svg")" alt="Tìm kiếm" class="search-bar__icon icon" />
                </button>
            </form>
        </div>

        <!-- Profile content -->
        <div class="profile-container">
            <div class="row gy-md-3">
                <!-- Sidebar giống hệt trang kia -->
                <div class="col-3 col-xl-4 d-lg-none">
                    <div id="profile-sidebar"></div>
                </div>
                <!-- Content -->
                <div class="col-9 col-xl-8 col-lg-12">
                    <div class="cart-info">
                        <div class="row gy-3">
                            <div class="col-12">
                                <h2 class="cart-info__heading">
                                    <a href="@Url.Action("Index", "Profile")" aria-label="Quay lại hồ sơ">
                                        <img src="@Url.Content("~/Content/icons/arrow-left.svg")" alt class="icon cart-info__back-arrow" />
                                    </a>
                                    Đổi mật khẩu
                                </h2>
                                <form id="change-pass-form" class="form form-card" novalidate>
                                    <div class="form__row">
                                        <div class="form__group">
                                            <label for="password-current" class="form__label form-card__label">Mật khẩu hiện tại</label>
                                            <div class="form__text-input">
                                                <input type="password" id="password-current" placeholder="Mật khẩu hiện tại"
                                                    class="form__input" required />
                                                <img src="@Url.Content("~/Content/icons/form-error.svg")" alt class="form__input-icon-error" />
                                            </div>
                                            <p class="form__error" id="err-pass-current" style="display:none">Vui lòng nhập mật khẩu hiện tại</p>
                                        </div>
                                        <div class="form__group">
                                            <label for="password-new" class="form__label form-card__label">Mật khẩu mới</label>
                                            <div class="form__text-input">
                                                <input type="password" id="password-new" placeholder="Mật khẩu mới (≥ 6 ký tự)"
                                                    class="form__input" required />
                                                <img src="@Url.Content("~/Content/icons/form-error.svg")" alt class="form__input-icon-error" />
                                            </div>
                                            <p class="form__error" id="err-pass-new" style="display:none">Mật khẩu mới tối thiểu 6 ký tự</p>
                                        </div>
                                    </div>
                                    <div class="form__row">
                                        <div class="form__group">
                                            <label for="password-confirm" class="form__label form-card__label">Xác nhận mật khẩu mới</label>
                                            <div class="form__text-input">
                                                <input type="password" id="password-confirm" placeholder="Nhập lại mật khẩu mới"
                                                    class="form__input" required />
                                                <img src="@Url.Content("~/Content/icons/form-error.svg")" alt class="form__input-icon-error" />
                                            </div>
                                            <p class="form__error" id="err-pass-confirm" style="display:none">Mật khẩu xác nhận không khớp</p>
                                        </div>
                                    </div>
                                    <div class="form-card__bottom">
                                        <a class="btn btn--text" href="@Url.Action("Index", "Profile")">Hủy</a>
                                        <button class="btn btn--primary btn--rounded" type="submit">Đổi mật khẩu</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- /Content -->
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script src="@Url.Content("~/Content/js/change-password.js")"></script>
    <script src="@Url.Content("~/Content/js/profile-sidebar.js")"></script>
}

