@{
    ViewBag.Title = "Chỉnh sửa thông tin | Shark Tank";
    Layout = "~/Views/Shared/_Layout.cshtml";
    Response.ContentType = "text/html; charset=utf-8";
    Response.Charset = "utf-8";
}

<!-- MAIN -->
<main class="profile">
    <div class="container">
        <!-- Search bar -->
        <div class="profile-container">
            <form class="search-bar d-none d-md-flex" role="search" aria-label="Tìm kiếm" onsubmit="return false;">
                <input type="search" id="profile-search" placeholder="Tìm sản phẩm…"
                    class="search-bar__input" autocomplete="off" aria-label="Tìm sản phẩm" />
                <button class="search-bar__submit" type="button" aria-label="Tìm kiếm">
                    <img src="@Url.Content("~/Content/icons/search.svg")" alt="Tìm kiếm" class="search-bar__icon icon" />
                </button>
            </form>
        </div>

        <!-- Profile content -->
        <div class="profile-container">
            <div class="row gy-md-3">
                <!-- Ẩn sidebar ở màn lớn như bản gốc -->
                <div class="col-3 col-xl-4 d-lg-none">
                    <div id="profile-sidebar"></div>
                </div>
                <div class="col-9 col-xl-8 col-lg-12">
                    <div class="cart-info">
                        <div class="row gy-3">
                            <div class="col-12">
                                <h2 class="cart-info__heading">
                                    <a href="@Url.Action("Index", "Profile")" aria-label="Quay lại hồ sơ">
                                        <img src="@Url.Content("~/Content/icons/arrow-left.svg")" alt class="icon cart-info__back-arrow" />
                                    </a>
                                    Thông tin cá nhân
                                </h2>
                                <form id="profile-form" class="form form-card" novalidate>
                                    <!-- Form row 1 -->
                                    <div class="form__row">
                                        <div class="form__group">
                                            <label for="full-name" class="form__label form-card__label">Họ và tên</label>
                                            <div class="form__text-input">
                                                <input type="text" id="full-name" placeholder="Họ và tên"
                                                    class="form__input" required autofocus />
                                                <img src="@Url.Content("~/Content/icons/form-error.svg")" alt class="form__input-icon-error" />
                                            </div>
                                            <p class="form__error" id="err-name">Vui lòng nhập họ và tên</p>
                                        </div>
                                        <div class="form__group">
                                            <label for="email-address" class="form__label form-card__label">Email</label>
                                            <div class="form__text-input">
                                                <input type="email" id="email-address" placeholder="Email"
                                                    class="form__input" required />
                                                <img src="@Url.Content("~/Content/icons/form-error.svg")" alt class="form__input-icon-error" />
                                            </div>
                                            <p class="form__error" id="err-email">Vui lòng nhập email hợp lệ</p>
                                        </div>
                                    </div>

                                    <!-- Form row 2 -->
                                    <div class="form__row">
                                        <div class="form__group">
                                            <label for="phone-number" class="form__label form-card__label">Số điện thoại</label>
                                            <div class="form__text-input">
                                                <input type="tel" id="phone-number" placeholder="Số điện thoại"
                                                    class="form__input" required />
                                                <img src="@Url.Content("~/Content/icons/form-error.svg")" alt class="form__input-icon-error" />
                                            </div>
                                            <p class="form__error" id="err-phone">Vui lòng nhập số điện thoại hợp lệ</p>
                                        </div>
                                    </div>

                                    <div class="form-card__bottom">
                                        <a class="btn btn--text" href="@Url.Action("Index", "Profile")">Hủy</a>
                                        <button class="btn btn--primary btn--rounded" type="submit">Lưu</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script src="@Url.Content("~/Content/js/profile-sidebar.js")"></script>
    <script src="@Url.Content("~/Content/js/profile-page.js")"></script>
}

