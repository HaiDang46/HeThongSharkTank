@{
    ViewBag.Title = "Địa Chỉ | Shark Tank";
    Layout = "~/Views/Shared/_Layout.cshtml";
    Response.ContentType = "text/html; charset=utf-8";
    Response.Charset = "utf-8";
}

<style>



        .subtitle {
            color: #666;
            margin-bottom: 30px;
            font-size: 14px;
        }

        .form-row {
            display: flex;
            gap: 16px;
            margin-bottom: 20px;
        }

        .form-group {
            flex: 1;
            position: relative;
        }

        /* Chỉ áp dụng cho label trong phần chọn địa chỉ */
        .form-row .form-group label {
            display: block;
            margin-bottom: 8px;
            font-size: 14px;
            color: #333;
            font-weight: 500;
        }

        /* Chỉ áp dụng cho input trong phần chọn địa chỉ (province, district, ward) */
        #province, #district, #ward {
            width: 100% !important;
            padding: 8px 12px !important;
            border: 1px solid #ddd !important;
            border-radius: 4px !important;
            font-size: 14px !important;
            outline: none !important;
            background: white !important;
        }

        #province:focus, #district:focus, #ward:focus {
            border-color: #3b82f6 !important;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1) !important;
        }

        .dropdown {
            position: absolute;
            top: 100%;
            left: 0;
            width: 100%;
            background: #f3f4f6;
            border: 1px solid #e5e7eb;
            border-radius: 4px;
            max-height: 12rem;
            overflow-y: auto;
            box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06);
            z-index: 10;
            display: none;
            margin-top: 2px;
        }

        .dropdown.show {
            display: block;
        }

        .dropdown ul {
            list-style: none;
            margin: 0;
            padding: 0;
        }

        .dropdown li {
            padding: 0.25rem 0.5rem;
            cursor: pointer;
            font-size: 14px;
            background: #fff;
            border-bottom: 1px solid #f3f4f6;
        }

        .dropdown li:last-child {
            border-bottom: none;
        }

        .dropdown li:hover {
            background: #dbeafe;
        }

        .info {
            margin-top: 30px;
            padding: 15px;
            background: #f0f9ff;
            border-left: 4px solid #3b82f6;
            border-radius: 4px;
        }

        .info h3 {
            font-size: 16px;
            margin-bottom: 10px;
            color: #1e40af;
        }

        .info ul {
            margin-left: 20px;
            color: #1e3a8a;
        }

        .info li {
            margin-bottom: 5px;
            font-size: 14px;
        }

        .selected-info {
            margin-top: 20px;
            padding: 15px;
            background: #f9fafb;
            border-radius: 4px;
            font-size: 14px;
        }

        .selected-info strong {
            color: #333;
        }

        .selected-info span {
            color: #666;
        }
    </style>
<main class="checkout-page">
    <div class="container">
        <div class="checkout-container">
            <div class="search-bar d-none d-md-flex">
                <input type="text" name id placeholder="Search for item" class="search-bar__input" />
                <button class="search-bar__submit">
                    <img src="@Url.Content("~/Content/icons/search.svg")" alt class="search-bar__icon icon" />
                </button>
            </div>
        </div>

        <div class="checkout-container">
            <ul class="breadcrumbs checkout-page__breadcrumbs">
                <li>
                    <a href="@Url.Action("Index", "Home")" class="breadcrumbs__link">
                        Trang Chủ
                        <img src="@Url.Content("~/Content/icons/arrow-right.svg")" alt />
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Index", "Checkout")" class="breadcrumbs__link">
                        Giỏ Hàng
                        <img src="@Url.Content("~/Content/icons/arrow-right.svg")" alt />
                    </a>
                </li>
                <li>
                    <a href="#!" class="breadcrumbs__link breadcrumbs__link--current">Địa Chỉ</a>
                </li>
            </ul>
        </div>

        <!-- Checkout content -->
        <div class="checkout-container">
            <div class="row gy-xl-3">
                <div class="col-8 col-xl-12">
                    <div class="cart-info">
                        <h1 class="cart-info__heading"></h1>
                        <div class="cart-info__separate"></div>

                        <!-- Checkout address -->
                        <div class="user-address">
                            @Html.AntiForgeryToken()
                            <div class="user-address__top">
                                <div>
                                    <h2 class="user-address__title">Địa chỉ giao hàng</h2>
                                    <p class="user-address__desc">Chúng tôi nên giao hàng cho bạn ở đâu?</p>
                                </div>
                                <button class="user-address__btn btn btn--primary btn--rounded btn--small js-toggle" toggle-target="#add-new-address">
                                    <img src="@Url.Content("~/Content/icons/plus.svg")" alt />
                                    Thêm địa chỉ mới
                                </button>
                            </div>
                            <div class="user-address__list" id="address-list">
                                @if (ViewBag.Addresses != null && ((List<WebSharkTank.Models.Address>)ViewBag.Addresses).Count > 0)
                                {
                                    foreach (var addr in (List<WebSharkTank.Models.Address>)ViewBag.Addresses)
                                    {
                                        <article class="address-card" data-address-id="@addr.Id">
                                    <div class="address-card__left">
                                        <div class="address-card__choose">
                                            <label class="cart-info__checkbox">
                                                        <input type="radio" name="shipping-address" value="@addr.Id" class="cart-info__checkbox-input" @(addr.IsDefault ? "checked" : "") />
                                            </label>
                                        </div>
                                        <div class="address-card__info">
                                                    <h3 class="address-card__title">@addr.Name</h3>
                                                    <p class="address-card__desc">@addr.StreetAddress</p>
                                            <ul class="address-card__list">
                                                        <li class="address-card__list-item">@addr.Province</li>
                                                        @* Tạm thời comment để tránh lỗi compile - sẽ bỏ comment sau khi rebuild project *@
                                                        @*@if (addr.District != null && !string.IsNullOrEmpty(addr.District))
                                                        {
                                                            <li class="address-card__list-item">@addr.District</li>
                                                        }
                                                        @if (addr.Ward != null && !string.IsNullOrEmpty(addr.Ward))
                                                        {
                                                            <li class="address-card__list-item">@addr.Ward</li>
                                                        }*@
                                                        <li class="address-card__list-item">@addr.Phone</li>
                                            </ul>
                                        </div>
                                    </div>
                                    <div class="address-card__right">
                                        <div class="address-card__ctrl">
                                                    <button class="cart-info__edit-btn btn-edit-address" type="button" data-id="@addr.Id" data-name="@addr.Name" data-phone="@addr.Phone" data-address="@addr.StreetAddress" data-province="@addr.Province" @*data-district="@(addr.District ?? "")" data-ward="@(addr.Ward ?? "")"*@ data-isdefault="@addr.IsDefault">
                                                <img class="icon" src="@Url.Content("~/Content/icons/edit.svg")" alt />
                                                Sửa
                                            </button>
                                                    <button class="cart-info__edit-btn btn-delete-address" type="button" data-id="@addr.Id" style="margin-left: 5px; color: red;">
                                                        <i class="fas fa-trash-alt"></i>
                                                        Xóa
                                            </button>
                                        </div>
                                    </div>
                                </article>
                                    }
                                }
                            </div>
                        </div>

                        <div class="cart-info__separate"></div>

                        <h2 class="cart-info__sub-heading">Chi tiết mặt hàng</h2>
                        <div class="cart-info__list"></div>
                        <div class="cart-info__bottom d-md-none">
                            <div class="row">
                                <div class="col-8 col-xxl-7">
                                    <div class="cart-info__continue">
                                        <a href="@Url.Action("Index", "Home")" class="cart-info__continue-link">
                                            <img class="cart-info__continue-icon icon" src="@Url.Content("~/Content/icons/arrow-down-2.svg")" alt />
                                            Tiếp Tục Mua Sắm
                                        </a>
                                    </div>
                                </div>
                                <div class="col-4 col-xxl-5">
                                    <div class="cart-info__row">
                                        <span>Tổng Phụ:</span>
                                        <span id="shipSubtotalMobile">0đ</span>
                                    </div>
                                    <div class="cart-info__row">
                                        <span>Phí Vận Chuyển:</span>
                                        <span id="shipShippingMobile">0đ</span>
                                    </div>
                                    <div class="cart-info__row cart-info__row--bold">
                                        <span>Tổng:</span>
                                        <span id="shipTotalMobile">0đ</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-4 col-xl-12">
                    <div class="cart-info">
                        <div class="cart-info__row">
                            <span>Mặt Hàng <span class="cart-info__sub-label"></span></span>
                            <span id="shipSubtotalItems">0</span>
                        </div>
                        <div class="cart-info__row">
                            <span>Giá <span class="cart-info__sub-label"></span></span>
                            <span id="shipSubtotalPrice">0đ</span>
                        </div>
                        <div class="cart-info__row">
                            <span>Phí vận Chuyển</span>
                            <span id="shipShipping">0đ</span>
                        </div>
                        <div class="cart-info__row">
                            <span>Tổng</span>
                            <span id="shipEstimatedTotal">0đ</span>
                        </div>

                        <a href="@Url.Action("Index", "Payment")" class="cart-info__next-btn btn btn--primary btn--rounded">
                            Tiếp Tục Thanh Toán
                        </a>
                    </div>
                    <div class="cart-info">
                        <a href="#!">
                            <article class="gift-item">
                                <div class="gift-item__icon-wrap">
                                    <img src="@Url.Content("~/Content/icons/gift.svg")" alt class="gift-item__icon" />
                                </div>
                                <div class="gift-item__content">
                                    <h3 class="gift-item__title">Gửi đơn hàng này như một món quà.</h3>
                                    <p class="gift-item__desc">
                                        Các mặt hàng có sẵn sẽ được chuyển đến người nhận quà của bạn.
                                    </p>
                                </div>
                            </article>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<!-- Modal: confirm remove shopping cart item -->
<div id="delete-confirm" class="modal modal--small hide">
    <div class="modal__content">
        <p class="modal__text">Do you want to remove this item from shopping cart?</p>
        <div class="modal__bottom">
            <button class="btn btn--small btn--outline modal__btn js-toggle" toggle-target="#delete-confirm">
                Cancel
            </button>
            <button class="btn btn--small btn--danger btn--primary modal__btn btn--no-margin js-toggle" toggle-target="#delete-confirm">
                Delete
            </button>
        </div>
    </div>
    <div class="modal__overlay js-toggle" toggle-target="#delete-confirm"></div>
</div>

<!-- Modal: address new shipping address -->
<div id="add-new-address" class="modal hide" style="--content-width: 650px;">
    <div class="modal__content">
        <form id="address-form" class="form">
            @Html.AntiForgeryToken()
            <h2 class="modal__heading">Thêm Địa chỉ giao hàng</h2>
            <div class="modal__body">
                <div class="form__row">
                    <div class="form__group">
                        <label for="address-name" class="form__label form__label--small">Họ và tên</label>
                        <div class="form__text-input form__text-input--small">
                            <input type="text" name="name" id="address-name" placeholder="Nhập họ và tên" class="form__input" required minlength="2" />
                            <img src="@Url.Content("~/Content/icons/form-error.svg")" alt class="form__input-icon-error" />
                        </div>
                        <p class="form__error">Họ và tên phải có ít nhất 2 ký tự</p>
                    </div>
                    <div class="form__group">
                        <label for="address-phone" class="form__label form__label--small">Số điện thoại</label>
                        <div class="form__text-input form__text-input--small">
                            <input type="tel" name="phone" id="address-phone" placeholder="Nhập số điện thoại" class="form__input" required minlength="10" />
                            <img src="@Url.Content("~/Content/icons/form-error.svg")" alt class="form__input-icon-error" />
                        </div>
                        <p class="form__error">Số điện thoại phải có ít nhất 10 số</p>
                    </div>
                </div>
                <div class="form__group">
                    <label for="address-street" class="form__label form__label--small">Địa chỉ</label>
                    <div class="form__text-area">
                        <textarea name="address" id="address-street" placeholder="Nhập địa chỉ chi tiết (số nhà, tên đường, phường/xã)" class="form__text-area-input" required></textarea>
                        <img src="@Url.Content("~/Content/icons/form-error.svg")" alt class="form__input-icon-error" />
                    </div>
                    <p class="form__error">Vui lòng nhập địa chỉ</p>
                </div>
                 <div class="container">


        <div class="form-row">
            <div class="form-group">
                <label for="province">Tỉnh/Thành phố</label>
                <input type="text" id="province" placeholder="Tỉnh..." readonly />
                <input type="hidden" id="province-code" />
                <div id="province-dropdown" class="dropdown">
                    <ul id="province-list"></ul>
                        </div>
                    </div>

            <div class="form-group">
                <label for="district">Quận/Huyện</label>
                <input type="text" id="district" placeholder="Huyện..." readonly />
                <input type="hidden" id="district-code" />
                <div id="district-dropdown" class="dropdown">
                    <ul id="district-list"></ul>
                </div>
            </div>

            <div class="form-group">
                <label for="ward">Phường/Xã</label>
                <input type="text" id="ward" placeholder="Xã..." readonly />
                <input type="hidden" id="ward-code" />
                <div id="ward-dropdown" class="dropdown">
                    <ul id="ward-list"></ul>
                </div>
            </div>
        </div>

        <div class="selected-info">
            <strong>Đã chọn:</strong><br>
            <span id="selected-info">Chưa chọn</span>
        </div>

        <div class="info">
            <h3>Thông tin API</h3>
            <ul>
                <li>API Base: <code>https://provinces.open-api.vn/api/v1</code></li>
                <li>Lấy danh sách tỉnh: <code>GET /api/v1/p/</code></li>
            </ul>
        </div>
                </div>
            </div>
            <div class="modal__bottom">
                <button type="button" class="btn btn--small btn--text modal__btn js-toggle" toggle-target="#add-new-address">
                    Hủy
                </button>
                <button type="submit" class="btn btn--small btn--primary modal__btn btn--no-margin" id="btn-save-address">
                    Lưu
                </button>
            </div>
        </form>
    </div>
    <div class="modal__overlay js-toggle" toggle-target="#add-new-address"></div>
</div>

@section Scripts {
    <script src="@Url.Content("~/Scripts/jquery-3.7.0.min.js")"></script>
    <script>
        // Expose URL cho shipping.js
        window.SHIPPING_SET_SELECTED_ITEMS_URL = '@Url.Action("SetSelectedItems", "Shipping")';
        window.SHIPPING_SET_SELECTED_ADDRESS_URL = '@Url.Action("SetSelectedAddress", "Shipping")';
    </script>
    <script src="@Url.Content("~/Content/js/shipping.js")"></script>
    <script src="@Url.Content("~/Content/js/sticky.js")"></script>
    
    <script>
        // Đảm bảo jQuery đã load trước khi chạy code
        (function() {
            // Đợi jQuery load xong
            function waitForJQuery(callback) {
                if (typeof jQuery !== 'undefined') {
                    callback();
                } else {
                    setTimeout(function() {
                        waitForJQuery(callback);
                    }, 50);
                }
            }
            
            waitForJQuery(function() {
                // jQuery đã sẵn sàng
                if (typeof jQuery === 'undefined') {
                    console.error('jQuery is not loaded');
                    return;
                }

            // ===== PROVINCE/DISTRICT/WARD SELECTION - MOVED TO END OF FILE =====

            // ===== FORM SUBMIT & OTHER FUNCTIONS =====
            jQuery(document).ready(function() {

                // Submit form lưu địa chỉ
                jQuery('#address-form').off('submit').on('submit', function(e) {
                    e.preventDefault();
                    
                    var name = jQuery('#address-name').val().trim();
                    var phone = jQuery('#address-phone').val().trim();
                    var address = jQuery('#address-street').val().trim();
                    var province = jQuery('#province').val().trim();
                    var district = jQuery('#district').val().trim() || null;
                    var ward = jQuery('#ward').val().trim() || null;
                    var isDefault = jQuery('#isDefault').is(':checked');
                    
                    // Validation
                    if (!name || name.length < 2) {
                        swal({
                            title: "Lỗi",
                            text: "Vui lòng nhập họ và tên (ít nhất 2 ký tự)",
                            icon: "error",
                            button: "OK"
                        });
                        return;
                    }
                    if (!phone || phone.length < 10) {
                        swal({
                            title: "Lỗi",
                            text: "Vui lòng nhập số điện thoại (ít nhất 10 số)",
                            icon: "error",
                            button: "OK"
                        });
                        return;
                    }
                    if (!address) {
                        swal({
                            title: "Lỗi",
                            text: "Vui lòng nhập địa chỉ",
                            icon: "error",
                            button: "OK"
                        });
                        return;
                    }
                    if (!province) {
                        swal({
                            title: "Lỗi",
                            text: "Vui lòng chọn Tỉnh/Thành phố",
                            icon: "error",
                            button: "OK"
                        });
                        return;
                    }
                    
                    // Lấy ID nếu đang sửa
                    var editId = jQuery('#address-form').data('edit-id');
                    
                    // Kiểm tra đăng nhập từ server trước
                    fetch('/Account/GetCurrentUser', {
                        cache: 'no-cache',
                        headers: { 'Cache-Control': 'no-cache' }
                    })
                    .then(response => response.json())
                    .then(authData => {
                        var isLoggedIn = authData.success && authData.authenticated && authData.user && authData.user.id;
                        
                        if (!isLoggedIn) {
                            swal({
                                title: "Cần đăng nhập",
                                text: "Bạn cần đăng nhập để lưu địa chỉ. Bạn có muốn chuyển đến trang đăng nhập không?",
                                icon: "warning",
                                buttons: {
                                    cancel: "Hủy",
                                    confirm: {
                                        text: "Đăng nhập",
                                        value: true
                                    }
                                }
                            }).then((willLogin) => {
                                if (willLogin) {
                                    window.location.href = '@Url.Action("Login", "Account")?ReturnUrl=/Shipping';
                                }
                            });
                            return;
                        }
                        
                        // Đã đăng nhập: Lưu địa chỉ
                        jQuery.ajax({
                            url: '@Url.Action("SaveAddress", "Shipping")',
                            type: 'POST',
                            data: {
                                name: name,
                                phone: phone,
                                address: address,
                                province: province,
                                district: district,
                                ward: ward,
                                isDefault: isDefault,
                                id: editId || null,
                                __RequestVerificationToken: jQuery('input[name="__RequestVerificationToken"]').val()
                            },
                            success: function(response) {
                                if (response && response.success) {
                                    swal({
                                        title: "Thành công!",
                                        text: response.message || 'Đã lưu địa chỉ thành công!',
                                        icon: "success",
                                        button: "OK"
                                    }).then(() => {
                                        // Đóng modal
                                        jQuery('#add-new-address').addClass('hide');
                                        // Reset form
                                        jQuery('#address-form')[0].reset();
                                        jQuery('#province').val('');
                                        jQuery('#district').val('');
                                        jQuery('#ward').val('');
                                        jQuery('#province-code').val('');
                                        jQuery('#district-code').val('');
                                        jQuery('#ward-code').val('');
                                        jQuery('#address-form').removeData('edit-id');
                                        // Reload trang để hiển thị địa chỉ mới
                                        location.reload();
                                    });
                                } else {
                                    swal({
                                        title: "Lỗi",
                                        text: response && response.message ? response.message : 'Có lỗi xảy ra khi lưu địa chỉ',
                                        icon: "error",
                                        button: "OK"
                                    });
                                }
                            },
                            error: function(xhr) {
                                var errorMsg = 'Có lỗi xảy ra khi lưu địa chỉ';
                                if (xhr.responseJSON && xhr.responseJSON.message) {
                                    errorMsg = xhr.responseJSON.message;
                                }
                                swal({
                                    title: "Lỗi",
                                    text: errorMsg,
                                    icon: "error",
                                    button: "OK"
                                });
                            }
                        });
                    })
                    .catch(error => {
                        console.error('[Shipping] Error checking login:', error);
                        swal({
                            title: "Lỗi",
                            text: "Không thể kiểm tra đăng nhập. Vui lòng thử lại.",
                            icon: "error",
                            button: "OK"
                        });
                    });
                });

                // Xóa địa chỉ
                jQuery(document).off('click', '.btn-delete-address').on('click', '.btn-delete-address', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    
                    var id = jQuery(this).data('id');
                    if (!id) return;
                    
                    if (!confirm('Bạn có chắc chắn muốn xóa địa chỉ này?')) {
                        return;
                    }
                    
                    jQuery.ajax({
                        url: '@Url.Action("DeleteAddress", "Shipping")',
                        type: 'POST',
                        data: {
                            id: id,
                            __RequestVerificationToken: jQuery('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response && response.success) {
                                alert(response.message || 'Đã xóa địa chỉ thành công!');
                                location.reload();
                            } else {
                                alert(response && response.message ? response.message : 'Có lỗi xảy ra khi xóa địa chỉ');
                            }
                        },
                        error: function() {
                            alert('Có lỗi xảy ra khi xóa địa chỉ');
                        }
                    });
                });

                // Sửa địa chỉ - mở modal với dữ liệu
                jQuery(document).off('click', '.btn-edit-address').on('click', '.btn-edit-address', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    
                    var id = jQuery(this).data('id');
                    var name = jQuery(this).data('name');
                    var phone = jQuery(this).data('phone');
                    var address = jQuery(this).data('address');
                    var isDefault = jQuery(this).data('isdefault') === 'True' || jQuery(this).data('isdefault') === true;
                    
                    // Điền dữ liệu vào form
                    jQuery('#address-name').val(name);
                    jQuery('#address-phone').val(phone);
                    jQuery('#address-street').val(address);
                    jQuery('#isDefault').prop('checked', isDefault);
                    
                    // Lưu ID để biết là đang sửa
                    jQuery('#address-form').data('edit-id', id);
                    
                    // Mở modal
                    jQuery('#add-new-address').removeClass('hide');
                });

                // Mở modal thêm địa chỉ - gắn trực tiếp vào button với priority cao
                // Sử dụng namespace để có thể remove sau
                jQuery(document).off('click.openModal', '.user-address__btn').on('click.openModal', '.user-address__btn', function(e) {
                    e.preventDefault();
                    e.stopImmediatePropagation(); // Ngăn các handler khác chạy
                    
                    console.log('Button clicked to open modal');
                    var modal = jQuery('#add-new-address');
                    console.log('Modal found:', modal.length > 0);
                    
                    if (modal.length > 0) {
                        // Đang mở modal - remove hide và add show, set display
                        modal.removeClass('hide')
                              .addClass('show')
                              .css('display', 'flex')
                              .css('opacity', '1')
                              .css('visibility', 'visible');
                        
                        // Thêm style inline với !important bằng cách set attribute
                        modal.attr('style', modal.attr('style') + '; display: flex !important; opacity: 1 !important; visibility: visible !important;');
                        
                        console.log('Modal opened, classes:', modal.attr('class'));
                        console.log('Modal display:', modal.css('display'));
                        console.log('Modal opacity:', modal.css('opacity'));
                        console.log('Modal visibility:', modal.css('visibility'));
                        console.log('Modal style:', modal.attr('style'));
                        
                        // Reset form
                        setTimeout(function() {
                            var form = jQuery('#address-form');
                            if (form.length > 0) {
                                form[0].reset();
                                form.removeData('edit-id');
                            }
                        }, 100);
                    } else {
                        console.error('Modal #add-new-address not found!');
                    }
                    
                    return false; // Ngăn event bubble
                });
                
                // Đóng modal khi click vào overlay
                jQuery('#add-new-address .modal__overlay').off('click').on('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    var modal = jQuery('#add-new-address');
                    modal.removeClass('show')
                          .addClass('hide')
                          .css({
                              'display': 'none',
                              'opacity': '0',
                              'visibility': 'hidden'
                          });
                });
                
                // Đóng modal khi click vào nút Hủy
                jQuery('#add-new-address [toggle-target="#add-new-address"]').off('click').on('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    var modal = jQuery('#add-new-address');
                    modal.removeClass('show')
                          .addClass('hide')
                          .css({
                              'display': 'none',
                              'opacity': '0',
                              'visibility': 'hidden'
                          });
                });
                
                // Ngăn đóng modal khi click vào nội dung modal
                jQuery('#add-new-address .modal__content').off('click').on('click', function(e) {
                    e.stopPropagation();
                });
                }); // End jQuery(document).ready
                
                // Lưu địa chỉ được chọn vào localStorage khi user chọn radio button
                jQuery(document).on('change', 'input[name="shipping-address"]', function() {
                    var addressId = jQuery(this).val();
                    if (addressId) {
                        console.log('[Shipping] Address selected, saving to localStorage:', addressId);
                        // Lưu vào localStorage
                        localStorage.setItem('selectedAddressId', addressId);
                        // Lưu vào biến tạm để dùng khi chuyển sang Payment
                        window.__selectedAddressId = addressId;
                    }
                });
            }); // End waitForJQuery callback
        })();
    </script>
    <script>
        // API v1 endpoints
        const API_BASE = "https://provinces.open-api.vn/api/v1";
        const API_PROVINCE = `${API_BASE}/p/`;
        const API_PROVINCE_DETAIL = code => `${API_BASE}/p/${code}?depth=2`;
        const API_DISTRICT_DETAIL = code => `${API_BASE}/d/${code}?depth=2`;

        let DISTRICTS = [];
        let WARDS = [];

        function openDropdown(id) {
            document.getElementById(id).classList.add('show');
        }

        function closeDropdown(id) {
            document.getElementById(id).classList.remove('show');
        }

        function updateSelectedInfo() {
            const province = document.getElementById('province').value || '';
            const district = document.getElementById('district').value || '';
            const ward = document.getElementById('ward').value || '';
            
            const parts = [];
            if (province) parts.push(`Tỉnh: ${province}`);
            if (district) parts.push(`Huyện: ${district}`);
            if (ward) parts.push(`Xã: ${ward}`);
            
            document.getElementById('selected-info').textContent = 
                parts.length > 0 ? parts.join(' | ') : 'Chưa chọn';
        }

        // Load tỉnh
        function loadProvinces() {
            fetch(API_PROVINCE)
                .then(r => r.json())
                .then(list => {
                    const ul = document.getElementById('province-list');
                    ul.innerHTML = '';
                    list.forEach(p => {
                        const li = document.createElement('li');
                        li.textContent = p.name;
                        li.setAttribute('data-code', p.code);
                        li.setAttribute('data-name', p.name);
                        li.onclick = function() {
                            selectProvince(p.code, p.name);
                        };
                        ul.appendChild(li);
                    });
                    openDropdown('province-dropdown');
                })
                .catch(err => {
                    console.error("Error loading provinces:", err);
                    document.getElementById('province-list').innerHTML = 
                        '<li style="color: red;">Lỗi khi tải danh sách tỉnh</li>';
                });
        }

        // Load huyện
        function loadDistricts(code) {
            const ul = document.getElementById('district-list');
            ul.innerHTML = '<li>Đang tải...</li>';
            openDropdown('district-dropdown');
            
            fetch(API_PROVINCE_DETAIL(code))
                .then(r => r.json())
                .then(data => {
                    DISTRICTS = data.districts || [];
                    ul.innerHTML = '';
                    if (DISTRICTS.length === 0) {
                        ul.innerHTML = '<li style="color: #999;">Không có dữ liệu</li>';
                    } else {
                        DISTRICTS.forEach(d => {
                            const li = document.createElement('li');
                            li.textContent = d.name;
                            li.setAttribute('data-code', d.code);
                            li.setAttribute('data-name', d.name);
                            li.onclick = function() {
                                selectDistrict(d.code, d.name);
                            };
                            ul.appendChild(li);
                        });
                    }
                })
                .catch(err => {
                    console.error("Error loading districts:", err);
                    ul.innerHTML = '<li style="color: red;">Lỗi khi tải danh sách huyện</li>';
                });
        }

        // Load xã
        function loadWards(code) {
            const ul = document.getElementById('ward-list');
            ul.innerHTML = '<li>Đang tải...</li>';
            openDropdown('ward-dropdown');
            
            fetch(API_DISTRICT_DETAIL(code))
                .then(r => r.json())
                .then(data => {
                    WARDS = data.wards || [];
                    ul.innerHTML = '';
                    if (WARDS.length === 0) {
                        ul.innerHTML = '<li style="color: #999;">Không có dữ liệu</li>';
                    } else {
                        WARDS.forEach(w => {
                            const li = document.createElement('li');
                            li.textContent = w.name;
                            li.setAttribute('data-code', w.code);
                            li.setAttribute('data-name', w.name);
                            li.onclick = function() {
                                selectWard(w.code, w.name);
                            };
                            ul.appendChild(li);
                        });
                    }
                })
                .catch(err => {
                    console.error("Error loading wards:", err);
                    ul.innerHTML = '<li style="color: red;">Lỗi khi tải danh sách xã</li>';
                });
        }

        // Select province
        function selectProvince(code, name) {
            document.getElementById('province').value = name;
            document.getElementById('province-code').value = code;
            closeDropdown('province-dropdown');

            // Reset district and ward
            document.getElementById('district').value = '';
            document.getElementById('district-code').value = '';
            document.getElementById('ward').value = '';
            document.getElementById('ward-code').value = '';

            loadDistricts(code);
            updateSelectedInfo();
        }

        // Select district
        function selectDistrict(code, name) {
            document.getElementById('district').value = name;
            document.getElementById('district-code').value = code;
            closeDropdown('district-dropdown');

            // Reset ward
            document.getElementById('ward').value = '';
            document.getElementById('ward-code').value = '';

            loadWards(code);
            updateSelectedInfo();
        }

        // Select ward
        function selectWard(code, name) {
            document.getElementById('ward').value = name;
            document.getElementById('ward-code').value = code;
            closeDropdown('ward-dropdown');
            updateSelectedInfo();
        }

        // Event listeners
        document.getElementById('province').addEventListener('click', function() {
            loadProvinces();
        });

        document.getElementById('district').addEventListener('click', function() {
            const provinceCode = document.getElementById('province-code').value;
            if (!provinceCode) {
                alert('Chọn tỉnh trước');
                return;
            }
            if (DISTRICTS.length === 0) {
                loadDistricts(provinceCode);
            } else {
                openDropdown('district-dropdown');
            }
        });

        document.getElementById('ward').addEventListener('click', function() {
            const districtCode = document.getElementById('district-code').value;
            if (!districtCode) {
                alert('Chọn huyện trước');
                return;
            }
            if (WARDS.length === 0) {
                loadWards(districtCode);
            } else {
                openDropdown('ward-dropdown');
            }
        });

        // Close dropdowns when clicking outside
        document.addEventListener('click', function(e) {
            if (!e.target.closest('.form-group')) {
                closeDropdown('province-dropdown');
                closeDropdown('district-dropdown');
                closeDropdown('ward-dropdown');
            }
        });

        // Kiểm tra đăng nhập từ SERVER (API) - chính xác hơn Session
        (function() {
            var maxRetries = 50; // Tối đa 5 giây (50 * 100ms)
            var retryCount = 0;
            
            function checkLoginAndShowAlert() {
                // Kiểm tra đăng nhập từ server API
                fetch('/Account/GetCurrentUser', {
                    cache: 'no-cache',
                    headers: { 'Cache-Control': 'no-cache' }
                })
                .then(response => response.json())
                .then(data => {
                    var isLoggedIn = data.success && data.authenticated && data.user && data.user.id;
                    console.log('[Shipping] API check - isLoggedIn:', isLoggedIn);
                    
                    if (!isLoggedIn) {
                        // Chưa đăng nhập - hiển thị SweetAlert
                        showLoginAlert();
                    } else {
                        console.log('[Shipping] User is logged in, no alert needed');
                    }
                })
                .catch(error => {
                    console.error('[Shipping] Error checking login:', error);
                    // Nếu có lỗi, vẫn hiển thị alert để đảm bảo an toàn
                    showLoginAlert();
                });
            }
            
            // Đợi SweetAlert load xong
            function showLoginAlert() {
                if (typeof swal !== 'undefined') {
                    console.log('[Shipping] Showing login alert');
                    swal({
                        title: "Cần đăng nhập",
                        text: "Bạn cần đăng nhập để tiếp tục. Bạn có muốn chuyển đến trang đăng nhập không?",
                        icon: "warning",
                        buttons: {
                            cancel: "Hủy",
                            confirm: {
                                text: "Đăng nhập",
                                value: true
                            }
                        }
                    }).then((willLogin) => {
                        if (willLogin) {
                            // Chọn "Đăng nhập" → chuyển đến trang đăng nhập
                            window.location.href = '@Url.Action("Login", "Account")?ReturnUrl=/Shipping';
                        } else {
                            // Chọn "Hủy" → thoát ra trang Home
                            window.location.href = '@Url.Action("Index", "Home")';
                        }
                    });
                } else {
                    retryCount++;
                    if (retryCount < maxRetries) {
                        // Nếu SweetAlert chưa load, thử lại sau 100ms
                        console.log('[Shipping] SweetAlert not loaded yet, retrying... (' + retryCount + '/' + maxRetries + ')');
                        setTimeout(showLoginAlert, 100);
                    } else {
                        console.error('[Shipping] SweetAlert failed to load after ' + maxRetries + ' retries');
                        // Fallback: redirect về home
                        alert('Bạn cần đăng nhập để tiếp tục. Đang chuyển về trang chủ...');
                        window.location.href = '@Url.Action("Index", "Home")';
                    }
                }
            }
            
            // Chạy kiểm tra sau khi DOM sẵn sàng
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', function() {
                    setTimeout(checkLoginAndShowAlert, 300);
                });
            } else {
                setTimeout(checkLoginAndShowAlert, 300);
            }
        })();
    </script>
}

